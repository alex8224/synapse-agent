# ============================================================
# Synapse 环境变量模板（OpenAI 兼容优先）
# 复制为 .env 后填写密钥与模型信息：
#   cp .env.example .env
# ============================================================

# ---------- 必填：OpenAI 兼容模型 ----------
# 格式：openai:模型名
# 示例：openai:gpt-4.1 / openai:deepseek-chat / openai:qwen2.5-coder
MODEL=openai:gpt-4.1

# OpenAI 官方，或任意 OpenAI-compatible 网关/本地服务
OPENAI_API_KEY=
# 官方可留空；中转/本地通常填 .../v1
OPENAI_BASE_URL=

# ---------- 可选：Anthropic 原生 ----------
# MODEL=anthropic:claude-sonnet-4-0
ANTHROPIC_API_KEY=

# ---------- Agent 行为 ----------
WORKSPACE=.
AGENT_REQUIRE_APPROVAL=false
AGENT_AUTO_APPROVE=true

# ---------- LocalShell（无 sandbox） ----------
SHELL_TIMEOUT=120
MAX_OUTPUT_BYTES=100000
INHERIT_ENV=true
VIRTUAL_MODE=true
# 默认 pwsh（PowerShell 7+）；找不到时会回退 powershell
# 可选：cmd | bash | system | 绝对路径
SHELL_EXECUTABLE=pwsh
# SHELL_EXECUTABLE=cmd
# SHELL_EXECUTABLE=C:\Program Files\PowerShell\7\pwsh.exe
# 子进程 stdout/stderr 解码（默认 utf-8，避免中文 Windows GBK 解码失败）
SHELL_ENCODING=utf-8
SHELL_ENCODING_ERRORS=replace

# ---------- 会话 ----------
CHECKPOINT_BACKEND=sqlite
CHECKPOINT_PATH=.synapse/checkpoints.sqlite

# ---------- 观测（可选） ----------
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=synapse

AGENT_DEBUG=false

# ---------- 流式 / 并发 ----------
# token 级流式输出
TOKEN_STREAM=true
# 允许多工具同轮调用（模型侧 + 执行侧）
PARALLEL_TOOL_CALLS=true
# 并发工具执行上限
MAX_CONCURRENCY=8
# DeepSeek 等模型的 thinking / reasoning 文本流
ENABLE_THINKING=true
REASONING_EFFORT=high
